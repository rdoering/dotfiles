# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

if [[ -z "$TMUX" && -z "$HERDR_ENV" ]] && [[ -o interactive ]] && command -v tmux >/dev/null 2>&1
then
  tmux attach || tmux
fi
