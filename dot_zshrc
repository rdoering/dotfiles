export XDG_CONFIG_HOME=${HOME}/.config
export XDG_DATA_HOME=${HOME}/.local/share
export XDG_STATE_HOME=${HOME}/.local/state
export XDG_BIN_DIR=${HOME}/.local/bin


# link local brew
if [ -n "$(command -v brew)" ] && [ -e "${HOME}/.local/share/homebrew" ]
then
    local brew_prefix="${HOME}/.local"
    export HOMEBREW_PREFIX="$brew_prefix"
    export HOMEBREW_CELLAR="$brew_prefix/Cellar"
    export HOMEBREW_REPOSITORY="$brew_prefix/share/homebrew"
    export HOMEBREW_CASK_OPTS='${HOME}/Applications'
    export PATH="$brew_prefix/bin:$brew_prefix/sbin${PATH+:$PATH}"
    export MANPATH="$brew_prefix/share/man${MANPATH+:$MANPATH}:"
    export INFOPATH="$brew_prefix/share/info:${INFOPATH:-}"
