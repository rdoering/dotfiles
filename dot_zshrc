    # export HOMEBREW_NO_ENV_HINTS=1
fi

if [[ -d /etc/ssl/certs ]]
then
  export SSL_CERT_DIR=/etc/ssl/certs
fi

# Caches completion/init scripts of external tools, keyed by binary mtime.
# Re-runs the tool only when the binary is updated, otherwise the cached
# script is sourced directly. Uses the zsh stat builtin (no subprocess fork).
zmodload zsh/stat 2>/dev/null
_zsh_cache() {
  local name="$1" gen_cmd="$2"
  local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
  local tool="${gen_cmd%% *}"
  local bin
  bin=$(command -v "$tool" 2>/dev/null)
  [[ -z "$bin" ]] && return
  local ver
  stat -A ver +mtime "$bin" 2>/dev/null || ver="0"
  [[ -z "$ver" || "$ver" == "0" ]] && ver="noversion"
  local cache_file="$cache_dir/${name}_${ver}.zsh"
  if [[ ! -s "$cache_file" ]]; then
    mkdir -p "$cache_dir"
    command ${=gen_cmd} > "$cache_file" 2>/dev/null
    for f in "$cache_dir"/${name}_*.zsh(N); do
      [[ "$f" != "$cache_file" ]] && rm -f -- "$f"
    done
  fi
  [[ -s "$cache_file" ]] && source "$cache_file"
}

# Reevaluate the prompt string each time it's displaying a prompt
#setopt prompt_subst
#zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
#autoload bashcompinit && bashcompinit
autoload -Uz compinit
# refresh completion dump only once per day, otherwise load cached dump (-C);
# -i skips the insecure-directory audit (compaudit) for faster startup.
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit -i
else
  compinit -C -i
fi
# Verzeichnisse zuerst anzeigen
zstyle ':completion:*' list-dirs-first yes

# Interaktive Auswahl beim Drücken von Tab
zstyle ':completion:*' menu select

# tmux plugin manager
if [[ ! -d ~/.tmux/plugins/tpm ]]
then
  git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
fi

DISABLE_AUTO_UPDATE="true"
DISABLE_LS_COLORS="true"
setopt inc_append_history
setopt share_history
setopt MAGIC_EQUAL_SUBST
compdef -d php
export EDITOR=vi

# general key bindings
bindkey "\e[1;5C" forward-word
bindkey "\e[1;5D" backward-word

# docker alias
alias dc='docker compose'
alias d=docker

# ll using iso-format
export TIME_STYLE=long-iso

# Eza
alias l="eza -l --icons --git -a"
alias lt="eza --tree --level=2 --long --icons --git"
alias ltree="eza --tree --level=2  --icons --git"

# FZF
export FZF_DEFAULT_OPTS=" --color fg+:#ffffff,bg+:#777777"

if [ -x "/home/linuxbrew/.linuxbrew/bin/brew" ]
then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Füge ~/bin zu PATH hinzu, falls es existiert und noch nicht enthalten ist
if [ -d "$HOME/bin" ] && [[ ":$PATH:" != *":$HOME/bin:"* ]]; then
    PATH="$HOME/bin:$PATH"
    export PATH
fi

# Füge ~/.cargo/bin zu PATH hinzu, falls es existiert und noch nicht enthalten ist
if [ -d "$HOME/.cargo/bin" ] && [[ ":$PATH:" != *":$HOME/.cargo/bin:"* ]]; then
    PATH="$HOME/.cargo/bin:$PATH"
    export PATH
fi

# step CLI (smallstep) completion
if command -v step >/dev/null 2>&1
then
  _zsh_cache step "step completion zsh"
fi

# prompt
if command -v starship >/dev/null 2>&1
then
  _zsh_cache starship "starship init zsh"
  export STARSHIP_CONFIG=~/.config/starship/starship.toml
fi

# xozide als cd replacement
if command -v zoxide >/dev/null 2>&1
then
  _zsh_cache zoxide "zoxide init zsh"
  alias cd="z"
fi

# dot file management
if command -v chezmoi >/dev/null 2>&1
then
  _zsh_cache chezmoi "chezmoi completion zsh"
fi

# yazi - terminal file browser
if command -v yazi >/dev/null 2>&1
then
  function y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
      builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
  }
fi

# atuin - terminal history
if command -v atuin >/dev/null 2>&1
then
  _zsh_cache atuin "atuin init zsh --disable-up-arrow"
  _zsh_cache atuin-completions "atuin gen-completions --shell zsh"
fi

# kubectl - K8s management
if command -v kubectl >/dev/null 2>&1 && test -d ~/.kube/
then
  _zsh_cache kubectl "kubectl completion zsh"
  kubeconfigs=(~/.kube/config(N) ~/.kube/*.y*ml(N))
  if (( ${#kubeconfigs[@]} > 0 )); then
    export KUBECONFIG="${(j.:.)kubeconfigs}"
  fi
  alias k=kubectl
  alias kctx='kubectl config use-context'
fi

if command -v k3d >/dev/null 2>&1
then
  _zsh_cache k3d "k3d completion zsh"
fi

if command -v helm >/dev/null 2>&1
then
  _zsh_cache helm "helm completion zsh"
fi

if command -v gh  >/dev/null 2>&1
then
  _zsh_cache gh "gh completion --shell zsh"
fi


if command -v just  >/dev/null 2>&1
then
  _zsh_cache just "just --completions zsh"
fi

if command -v globalping >/dev/null 2>&1
then
  _zsh_cache globalping "globalping completion zsh"
fi

if command -v rg >/dev/null 2>&1; then
  _rg() {
    eval "$(rg --generate=complete-zsh | sed '1s/^/#compdef _rg rg\n/')"
  }
  compdef _rg rg
fi


if command -v nvim >/dev/null 2>&1; then
  alias v=nvim
  export EDITOR=nvim
elif command -v vi >/dev/null 2>&1; then
  alias v=vi
  export EDITOR=vi
fi


