#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
# current shell hash: {{ output "dscl" "." "-read" (printf "/Users/%s" .chezmoi.username) "UserShell" | sha256sum }}
{{- else -}}
# current shell hash: {{ output "getent" "passwd" .chezmoi.username | sha256sum }}
{{- end }}

set -euo pipefail

status_line() {
    local status="$1"
    local name="$2"
    local message="$3"
    local label="$status"

    case "$status" in
        ok) label=" ok " ;;
        *) label="$(printf '%-4s' "$status")" ;;
    esac

    printf '[%s] %-12s %s\n' "$label" "$name" "$message"
}

can_sudo() {
    command -v sudo >/dev/null 2>&1 || return 1
    sudo -k >/dev/null 2>&1
    sudo -n true >/dev/null 2>&1
}

# Prefer /bin/zsh on macOS — it is a Universal binary that runs arm64
# natively on Apple Silicon, avoiding Rosetta emulation. A brew zsh
# (/usr/local/bin/zsh on Intel, /opt/homebrew/bin/zsh on arm64) would also
# work but ties the login shell to brew. /bin/zsh is always present.
if [[ "$(uname -s)" == Darwin && -x /bin/zsh ]]; then
    zsh_path="/bin/zsh"
else
    zsh_path="$(command -v zsh 2>/dev/null)" || {
        status_line skip shell "zsh not found"
        exit 0
    }
fi

if [[ "$(uname -s)" == Darwin ]]; then
    current="$(dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}')"
else
    current="$(getent passwd "$USER" 2>/dev/null | cut -d: -f7)"
fi
[[ -z "$current" ]] && current="${SHELL:-}"

if [[ "$current" == "$zsh_path" ]]; then
    status_line skip shell "default already zsh"
    exit 0
fi

if ! can_sudo; then
    status_line skip shell "sudo needs password; run: chsh -s $zsh_path"
    exit 0
fi

if [[ -r /etc/shells ]] && ! grep -qxF "$zsh_path" /etc/shells; then
    echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
fi

sudo chsh -s "$zsh_path" "$USER"
status_line ok shell "default set to zsh; log out and back in"
