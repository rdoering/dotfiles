#!/bin/bash
{{ if eq .chezmoi.os "darwin" -}}
# current shell hash: {{ output "dscl" "." "-read" (printf "/Users/%s" .chezmoi.username) "UserShell" | sha256sum }}
{{- else -}}
# current shell hash: {{ output "getent" "passwd" .chezmoi.username | sha256sum }}
{{- end }}

set -euo pipefail

can_sudo() {
    command -v sudo >/dev/null 2>&1 || return 1
    sudo -k >/dev/null 2>&1
    sudo -n true >/dev/null 2>&1
}

zsh_path="$(command -v zsh 2>/dev/null)" || {
    echo "zsh not found, skipping..."
    exit 0
}

if [[ "$(uname -s)" == Darwin ]]; then
    current="$(dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}')"
else
    current="$(getent passwd "$USER" 2>/dev/null | cut -d: -f7)"
fi
[[ -z "$current" ]] && current="${SHELL:-}"

if [[ "$current" == "$zsh_path" ]]; then
    echo "default shell already zsh, skipping..."
    exit 0
fi

if ! can_sudo; then
    echo "cannot set default shell to zsh (sudo needs password); run manually: chsh -s $zsh_path"
    exit 0
fi

if [[ -r /etc/shells ]] && ! grep -qxF "$zsh_path" /etc/shells; then
    echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
fi

sudo chsh -s "$zsh_path" "$USER"
echo "default shell set to zsh (log out and back in)"
