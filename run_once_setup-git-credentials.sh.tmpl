#!/bin/bash
set -e

CREDENTIALS_FILE="$HOME/.local/share/chezmoi/private_dot_config/git-credentials.txt.age"

status_line() {
    local status="$1"
    local name="$2"
    local message="$3"
    local label="$status"

    case "$status" in
        ok) label=" ok " ;;
        *) label="$(printf '%-4s' "$status")" ;;
    esac

    printf '[%s] %-12s %s\n' "$label" "$name" "$message"
}

# Check if credentials already exist
if [ -f "$CREDENTIALS_FILE" ]; then
    status_line skip git "credentials already exist"
    exit 0
fi

status_line run git "setting up credentials"

# Prompt for name (with default)
read -p "Git user name [rdoering]: " GIT_NAME
GIT_NAME=${GIT_NAME:-rdoering}

# Prompt for email
read -p "Git email [rdoering.info@gmail.com]: " GIT_EMAIL
GIT_EMAIL=${GIT_EMAIL:-rdoering.info@gmail.com}

# Create temporary credentials file
TEMP_FILE=$(mktemp)
cat > "$TEMP_FILE" << EOF
name=$GIT_NAME
email=$GIT_EMAIL
EOF

# Encrypt with age
age -r age1e6rgau5x2tf64mavjw8wwnl09r2eyf6ja9yrrzvtvjd7l7q09afq0aqy2x \
    -o "$CREDENTIALS_FILE" \
    "$TEMP_FILE"

# Cleanup
rm -f "$TEMP_FILE"

status_line ok git "credentials encrypted and saved"
