{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "temperature": 0.1,
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      },
      "permission": {
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow",
          "grep *": "allow",
          "rg *": "allow"
        }
      }
    },
    "ask": {
      "mode": "primary",
      "prompt": "You have access to no tools, you can only respond to questions",
      "tools": {
        "*": false
      }
    }
  },
  "mcp": {
    "gitlab": {
      "type": "remote",
      "url": "https://gitlab.int.quentic.com/api/v4/mcp",
      "enabled": false
    },
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false
    }
  },
  "plugin": [],
  "provider": {},
  "experimental": {
    "disable_paste_summary": false
  }
}
